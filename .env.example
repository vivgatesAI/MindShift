# MindShift Environment Variables
# Copy this to .env.local for development, and set these in Railway for production

# Venice AI API Key (required)
VENICE_API_KEY=your_venice_api_key_here

# Database URL (Railway provides this)
DATABASE_URL=postgresql://user:password@localhost:5432/mindshift

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000