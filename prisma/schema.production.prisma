// Production schema for Railway (PostgreSQL)
// This file is used when deploying to Railway
// To switch: copy this content to prisma/schema.prisma and set DATABASE_URL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  passcode  String?
  createdAt DateTime @default(now())

  thoughtRecords ThoughtRecord[]
  chatMessages   ChatMessage[]
}

model ThoughtRecord {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime @default(now())
  situation          String?
  emotions           String?
  emotionIntensity   Int?
  physicalSensations  String?
  thoughts           String?
  behaviors          String?
  cognitiveDistortions String? // JSON array
  reframedThoughts   String?   // JSON array
  aiAnalysis          String?   // JSON
  summary             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([userId, date])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  recordId  String?
  role      String   // "user" | "assistant"
  content   String
  audioUrl  String?
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  record ThoughtRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([recordId])
}